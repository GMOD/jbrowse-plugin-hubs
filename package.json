{
  "version": "1.0.9",
  "license": "MIT",
  "name": "@cmdcolin/jbrowse-plugin-hubs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GMOD/jbrowse-plugin-hubs.git"
  },
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "start": "node esbuild.mjs --watch",
    "test": "echo 'no tests'",
    "format": "pnpm prettier --write .",
    "prebuild": "pnpm clean",
    "build": "tsc && NODE_ENV=production node esbuild.mjs",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "prepack": "pnpm build",
    "postversion": "git push --follow-tags",
    "preversion": "pnpm lint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@jbrowse/core": "^4.3.0",
    "@jbrowse/mobx-state-tree": "^5.11.1",
    "@mui/material": "^7.3.11",
    "@mui/system": "^7.3.11",
    "@mui/x-data-grid": "^8.29.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "esbuild": "^0.27.7",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "mobx": "^6.16.1",
    "mobx-react": "^9.2.2",
    "prettier": "^3.8.4",
    "pretty-bytes": "^7.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "serve": "^14.2.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
