{
  "version": "1.0.8",
  "license": "MIT",
  "name": "@cmdcolin/jbrowse-plugin-hubs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GMOD/jbrowse-plugin-hubs.git"
  },
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "start": "node esbuild.mjs --watch",
    "test": "echo 'no tests'",
    "format": "pnpm prettier --write .",
    "prebuild": "pnpm clean",
    "build": "tsc && NODE_ENV=production node esbuild.mjs",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "prepack": "pnpm build",
    "postversion": "git push --follow-tags",
    "preversion": "pnpm lint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@jbrowse/core": "^4.1.3",
    "@jbrowse/mobx-state-tree": "^5.0.2",
    "@mui/material": "^7.3.7",
    "@mui/system": "^7.3.7",
    "@mui/x-data-grid": "^8.26.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "esbuild": "^0.27.2",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "mobx": "^6.0.0",
    "mobx-react": "^9.0.1",
    "prettier": "^3.8.1",
    "pretty-bytes": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.2",
    "rxjs": "^7.8.1",
    "serve": "^14.2.0",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.59.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
